# ML Model Serving Platform — Environment Configuration

# Model storage
MODEL_STORE_PATH=./model_artifacts
REGISTRY_PATH=./model_registry
MAX_LOADED_MODELS=10

# Batching
BATCH_TIMEOUT_MS=50
BATCH_MAX_SIZE=32

# Monitoring
PROMETHEUS_PORT=9090

# Cloud (optional)
GCP_PROJECT=
GCP_REGION=us-central1
AWS_REGION=us-east-1
S3_BUCKET=

# Logging
LOG_LEVEL=INFO

# Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
